{
  "id": "memos-local-plugin",
  "name": "Local Memory Plugin",
  "description": "Local PostgreSQL/pgvector memory recall + save via lifecycle hooks",
  "version": "0.1.0",
  "kind": "lifecycle",
  "main": "./index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "pgHost": {
        "type": "string",
        "description": "PostgreSQL host (default: env PGHOST or 'server')"
      },
      "pgPort": {
        "type": "integer",
        "description": "PostgreSQL port (default: env PGPORT or 5432)",
        "default": 5432
      },
      "pgUser": {
        "type": "string",
        "description": "PostgreSQL user (default: env PGUSER or 'chloe')"
      },
      "pgPassword": {
        "type": "string",
        "description": "PostgreSQL password (default: env PGPASSWORD)"
      },
      "pgDatabase": {
        "type": "string",
        "description": "PostgreSQL database (default: env PGDATABASE or 'chloe')"
      },
      "openrouterApiKey": {
        "type": "string",
        "description": "OpenRouter API key for embeddings (default: env OPENROUTER_API_KEY)"
      },
      "embeddingModel": {
        "type": "string",
        "description": "Embedding model name",
        "default": "openai/text-embedding-3-small"
      },
      "recallEnabled": {
        "type": "boolean",
        "default": true
      },
      "addEnabled": {
        "type": "boolean",
        "default": true
      },
      "captureStrategy": {
        "type": "string",
        "enum": ["last_turn", "full_session"],
        "default": "last_turn"
      },
      "maxMessageChars": {
        "type": "integer",
        "description": "Max chars per message when saving",
        "default": 20000
      },
      "includeAssistant": {
        "type": "boolean",
        "default": true
      },
      "searchLimit": {
        "type": "integer",
        "description": "Max results per search (split between conversations and notes)",
        "default": 10
      },
      "timeoutMs": {
        "type": "integer",
        "default": 5000
      },
      "throttleMs": {
        "type": "integer",
        "default": 0
      }
    },
    "additionalProperties": false
  }
}
